{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["backend/**", "frontend/dist/**"]
      }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
 "routes": [
  {
    "src": "/api/(.*)",
    "dest": "/backend/app.js"
  },
  {
    "handle": "filesystem"
  },
  {
    "src": "/(.*)",
    "dest": "/frontend/index.html"
  }
]
}
